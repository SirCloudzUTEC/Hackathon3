# Base de la API. Se usa una ruta RELATIVA same-origin (/api/v1) que se reenvía
# al backend mediante proxy:
#   - dev:  server.proxy en vite.config.ts
#   - prod: rewrites en vercel.json
# Esto evita CORS por completo (incluido PATCH). Si prefieres llamar directo al
# backend, pon la URL absoluta: https://<backend-url>/api/v1
VITE_API_BASE_URL=/api/v1
